# ============================================================
# ANUBIS - Environment Variables
# Copy this file to .env and fill in your values
# Get each value from the URLs listed below
# ============================================================

# DEMO MODE - set to "true" to run entirely on mock data (no API keys needed)
# Great for testing before you have all keys set up
DEMO_MODE=true

# OpenWeatherMap - free at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_key_here

# Google Gemini - free at https://aistudio.google.com
GEMINI_API_KEY=your_key_here

# NewsAPI - free at https://newsapi.org/register
NEWSAPI_KEY=your_key_here

# OpenRouteService - free at https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=your_key_here

# Mapbox - free at https://account.mapbox.com/auth/signup
VITE_MAPBOX_TOKEN=your_key_here

# Backend URL (for frontend to know where the API is)
VITE_API_BASE_URL=http://localhost:8000

# Port
PORT=8000
